# Database
# Runtime pooler URL for the app.
MULTI_POSTGRES_PRISMA_URL=postgresql://user:password@host:6543/dbname?sslmode=require&pgbouncer=true

# Direct/non-pooling URL for Prisma migrations and seed.
MULTI_POSTGRES_URL_NON_POOLING=postgresql://user:password@host:5432/dbname?sslmode=require

# Local-only fallback for environments without a configured CA.
# Do not set this in production.
MULTI_POSTGRES_ALLOW_SELF_SIGNED=true

# Optional production CA bundle. Prefer this in production instead of self-signed mode.
MULTI_POSTGRES_SSL_CA=

# Auth
AUTH_SECRET=generate-a-long-secret
AUTH_URL=http://localhost:1500
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# App
NEXT_PUBLIC_APP_URL=http://localhost:1500

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Internal cron
CRON_SECRET=generate-a-long-secret

# Email
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=AionSite Shop <noreply@example.com>

# WhatsApp Cloud API
WHATSAPP_CLOUD_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# Uploads
BLOB_STORE_ID=store_...
BLOB_READ_WRITE_TOKEN=

# Observability
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
