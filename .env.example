# ─── Base de datos (PostgreSQL) ───────────────────────────────────────────────
# URL con pooler para runtime de la app (Prisma)
MULTI_POSTGRES_PRISMA_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# Solo para desarrollo local; no crear esta variable en Vercel
MULTI_POSTGRES_ALLOW_SELF_SIGNED=true

# CA de Supabase para validar TLS en producción (PEM completo; admite \\n)
MULTI_POSTGRES_SSL_CA=

# URL directa sin pooler para migraciones y seed
MULTI_POSTGRES_URL_NON_POOLING=postgresql://user:password@host:5432/dbname?sslmode=require

# ─── Auth (NextAuth v5) ───────────────────────────────────────────────────────
AUTH_SECRET=genera-un-secreto-largo-con-openssl-rand-base64-32
AUTH_URL=http://localhost:1500

# Google OAuth (opcional en local)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_CONNECT_CLIENT_ID=ca_...
CRON_SECRET=genera-un-secreto-largo

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:1500

# ─── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=AionSite <noreply@mercadolocal.mx>

# ─── Upload de imágenes (Vercel Blob) ─────────────────────────────────────────
BLOB_STORE_ID=store_...
BLOB_READ_WRITE_TOKEN=

# ─── Observabilidad (opcional) ──────────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
